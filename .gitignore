# Local settings
.claude/settings.local.json

# NOTE on extracted artefacts (MDX + images + tables + glyph manifests):
# These are COMMITTED to the repo so Amplify can build without re-running the
# extraction pipeline (which would require Python + LibreOffice on the build
# container, plus the source docx).  Run `python tools/extract/extract.py` and
# `python tools/extract/post_process.py` whenever the source docx changes, then
# commit the regenerated artefacts.
