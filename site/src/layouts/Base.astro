---
import "~/styles/globals.css";

interface Props {
  title: string;
  description?: string;
  showHeader?: boolean;
  /** Override the og:image (defaults to /og-image.png). Use an absolute path. */
  ogImage?: string;
  /** Page kind: "website" for homepage, "article" for chapter pages. */
  ogType?: "website" | "article";
  /** ISO date strings for article schema; ignored on website pages. */
  datePublished?: string;
  dateModified?: string;
  /** Chapter number (only meaningful for article pages). */
  chapterNumber?: number;
  /** Pre-built JSON-LD object(s) to inline into the page. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "Kim H. Veltman's Alphabets of Life, reimagined as an interactive scholarly edition tracing the journey of writing systems across world cultures.",
  showHeader = true,
  ogImage = "/og-image.png",
  ogType = "website",
  datePublished,
  dateModified,
  chapterNumber,
  jsonLd,
} = Astro.props;

const fullTitle = title === "Alphabets of Life" ? title : `${title} · Alphabets of Life`;
const siteUrl = (Astro.site ?? new URL("http://localhost:4321")).toString().replace(/\/$/, "");
const canonicalUrl = `${siteUrl}${Astro.url.pathname.replace(/\/$/, "")}/`;
const ogImageAbs = ogImage.startsWith("http") ? ogImage : `${siteUrl}${ogImage}`;

const author = {
  "@type": "Person",
  "name": "Kim H. Veltman",
  "description": "Canadian scholar of art, science, and the history of perspective and writing systems (1948–2020).",
  "sameAs": [
    "https://en.wikipedia.org/wiki/Kim_H._Veltman",
    "https://www.sumscorp.com/",
  ],
} as const;

const bookSchema = {
  "@context": "https://schema.org",
  "@type": "Book",
  "name": "Alphabets of Life",
  "alternateName": "Alphabets of Life — General Edition",
  "author": author,
  "publisher": {
    "@type": "Organization",
    "name": "Twinscorp",
    "address": { "@type": "PostalAddress", "addressLocality": "Smolensk", "addressCountry": "RU" },
  },
  "datePublished": "2014",
  "inLanguage": "en",
  "url": `${siteUrl}/`,
  "image": ogImageAbs,
  "description": "How runes and alphabets begin as alphabets of life — alpha vitae — reflecting body, mind and cosmos. A comparative study tracing writing systems from marks and breath through Sanskrit, Slavic, and Western alphabets.",
  "about": [
    "Alphabets", "Writing systems", "Comparative linguistics",
    "Slavic alphabets", "Sanskrit", "Phoenician alphabet",
    "Cultural history", "Symbolism",
  ],
} as const;

const finalJsonLd = jsonLd ?? bookSchema;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ctext y='52' font-size='52'%3E𓂀%3C/text%3E%3C/svg%3E" />
    <meta name="theme-color" content="#faf7f0" />
    <meta name="author" content="Kim H. Veltman" />

    {/* Fonts */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Spectral:ital,wght@0,300;0,400;0,500;0,600;1,400;1,500&family=Fraunces:opsz,wght@9..144,300;9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600&display=swap"
    />

    {/* Open Graph */}
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Alphabets of Life" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Alphabets of Life by Kim H. Veltman — an interactive edition" />
    <meta property="og:locale" content="en_US" />
    {ogType === "article" && datePublished && (
      <meta property="article:published_time" content={datePublished} />
    )}
    {ogType === "article" && dateModified && (
      <meta property="article:modified_time" content={dateModified} />
    )}
    {ogType === "article" && (
      <meta property="article:author" content="Kim H. Veltman" />
    )}
    {ogType === "article" && chapterNumber && (
      <meta property="article:section" content={`Chapter ${chapterNumber}`} />
    )}

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />
    <meta name="twitter:image:alt" content="Alphabets of Life — an interactive edition" />

    {/* Structured data (JSON-LD) */}
    <script type="application/ld+json" set:html={JSON.stringify(finalJsonLd)} />
  </head>
  <body>
    {showHeader && (
      <header class="site-header">
        <a class="brand" href="/">Alphabets of Life</a>
        <nav>
          <a href="/#chapters">Chapters</a>
        </nav>
      </header>
    )}

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <p>
        Adapted from Kim H. Veltman, <i>Alphabets of Life — General Edition</i> · Twinscorp, Smolensk, 2014.
      </p>
    </footer>

    <script>
      import mediumZoom from "medium-zoom";

      let zoom: ReturnType<typeof mediumZoom> | null = null;
      let attached = new WeakSet<HTMLImageElement>();

      function attach() {
        const imgs = document.querySelectorAll<HTMLImageElement>("[data-zoomable]");
        const fresh: HTMLImageElement[] = [];
        imgs.forEach((el) => { if (!attached.has(el)) { attached.add(el); fresh.push(el); } });
        if (fresh.length === 0 && zoom) return;
        if (!zoom) {
          zoom = mediumZoom(fresh, {
            background: "rgba(20, 16, 12, 0.92)",
            margin: 48,
            scrollOffset: 60,
          });
        } else {
          zoom.attach(...fresh);
        }
      }

      function initZoom() {
        attach();
        // Watch for newly-rendered figures (view transitions, hydration islands, etc.).
        // We skip mutations that medium-zoom itself caused (overlay open/close adds
        // .medium-zoom-* nodes to <body>), to avoid disrupting an active zoom.
        const obs = new MutationObserver((mutations) => {
          const meaningful = mutations.some((m) =>
            [...m.addedNodes].some(
              (n) =>
                n.nodeType === 1 &&
                !(n as Element).className?.toString().includes("medium-zoom"),
            ),
          );
          if (meaningful) attach();
        });
        obs.observe(document.body, { childList: true, subtree: true });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initZoom);
      } else {
        initZoom();
      }
      document.addEventListener("astro:page-load", initZoom);
    </script>
  </body>
</html>
